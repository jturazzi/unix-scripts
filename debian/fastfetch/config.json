{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "padding": {
            "top": 2
        }
    },
    "modules": [
        {
            "type": "title",
            "fqdn": true
        },
        "separator",
        {
            "type": "os",
            "key": "Système"
        },
        {
            "type": "host",
            "key": "Machine"
        },
        {
            "type": "kernel",
            "key": "Noyau"
        },
        {
            "type": "uptime",
            "key": "Activité"
        },
        {
            "type": "loadavg",
            "key": "Charge"
        },
        {
            "type": "processes",
            "key": "Processus"
        },
        {
            "type": "packages",
            "key": "Paquets"
        },
        {
            "type": "cpu",
            "key": "Processeur"
        },
        {
            "type": "cpuusage",
            "key": "Charge CPU"
        },
        {
            "type": "gpu",
            "key": "GPU",
            "driverSpecific": true,
            "temp": false
        },
        {
            "type": "memory",
            "key": "Mémoire"
        },
        {
            "type": "disk",
            "key": "Disques"
        },
        {
            "type": "publicip",
            "key": "IP Publique",
            "format": "{ip}",
            "timeout": 1000
        },
        {
            "type": "localip",
            "key": "IP Locale",
            "showIpv6": false,
            "showMac": false,
            "showSpeed": false,
            "showMtu": false,
            "showLoop": false,
            "showFlags": false,
            "showAllIps": true
        },
        {
            "type": "dns",
            "key": "DNS"
        }
    ]
}